# Rust
/target/

# End-to-end fixture run artifacts (the fixtures are standalone
# packages or workspaces: cargo may drop a lockfile, and the generate
# runs write their outputs under generated/ — for workspace fixtures,
# one level deeper inside the member)
crates/apps/frieze-cli/tests/fixtures/*/Cargo.lock
crates/apps/frieze-cli/tests/fixtures/*/generated/
crates/apps/frieze-cli/tests/fixtures/*/target/
crates/apps/frieze-cli/tests/fixtures/*/*/generated/

# Scratch / agent progress logs
.tmp/

# Local env
.env
.env.local

# OS / editor
.DS_Store

# insta — pending snapshots (kept transient; intentional updates land
# in the inline `assert_*_snapshot!` macro literal directly).
*.pending-snap
